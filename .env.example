VITE_APP_TITLE=Bah-a-Nacho-WebSite
VITE_APP_DESCRIPTION=Add logo to header project

# Supabase client-side configuration. Prefer the current publishable key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Legacy browser key fallback. Do not use service_role or secret keys here.
VITE_SUPABASE_ANON_KEY=

# Server/CLI only. Never reference this variable from browser code.
SUPABASE_DB_URL=postgresql://postgres.project-ref:password@pooler-host:5432/postgres
