{
  "name": "figma-make-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "format": "oxfmt",
    "db:migration:new": "pwsh -NoProfile -File scripts/supabase-migrate.ps1 new",
    "db:migration:s tatus": "pwsh -NoProfile -File scripts/supabase-migrate.ps1 status",
    "db:migration:plan": "pwsh -NoProfile -File scripts/supabase-migrate.ps1 plan",
    "db:migration:push": "pwsh -NoProfile -File scripts/supabase-migrate.ps1 push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "lucide-react": "^1.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.10.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "oxfmt": "^0.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0"
  }
}
